                  ))}
                </tr>
              ),
            )
          )}
        </tbody>
      </table>
    </div>
  );
}

interface TableStateRowProps {
  colSpan: number;
  error?: ReactNode;
  isLoading: boolean;
  messages?: TableStateMessages;
}

function TableStateRow({
  colSpan,
  error,
  isLoading,
  messages,
}: TableStateRowProps) {
  if (isLoading) {
