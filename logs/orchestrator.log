  caption?: ReactNode;
  columns: Array<TableColumn<Row>>;
  error?: ReactNode;
  getRowKey: (row: Row) => string;
  isLoading?: boolean;
  messages?: TableStateMessages;
  renderRow?: (row: Row) => ReactNode;
  rows: Row[];
}

function Table<Row>({
  caption,
  columns,
  error,
  getRowKey,
  isLoading = false,
  messages,
  renderRow,
  rows,
}: TableProps<Row>) {
  const colSpan = Math.max(columns.length, 1);
